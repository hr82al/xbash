#!/bin/sh
# Tests for READLINE_INPUT_FILTER and READLINE_INPUT_FILTER_LIB functionality.
# This tests the non-interactive parts (hex encode/decode, filter lifecycle,
# library loading) since interactive readline requires a pty.

THIS_SH="${THIS_SH:-../bash}"
TEST_DIR="$(cd "$(dirname "$0")" && pwd)"
PASS=0
FAIL=0

assert_eq() {
    local desc="$1" expected="$2" actual="$3"
    if [ "$expected" = "$actual" ]; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: $desc"
        echo "  expected: '$expected'"
        echo "  actual:   '$actual'"
    fi
}

assert_ok() {
    local desc="$1"
    shift
    if "$@" >/dev/null 2>&1; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: $desc (exit code $?)"
    fi
}

assert_fail() {
    local desc="$1"
    shift
    if "$@" >/dev/null 2>&1; then
        FAIL=$((FAIL + 1))
        echo "FAIL: $desc (expected failure, got success)"
    else
        PASS=$((PASS + 1))
    fi
}

# ------------------------------------------------------------------ #
# Test 1: Bash builds and runs without filter variables               #
# ------------------------------------------------------------------ #

assert_ok "bash runs without filters" \
    "$THIS_SH" -c 'echo hello'

result=$("$THIS_SH" -c 'echo hello')
assert_eq "basic output" "hello" "$result"

# ------------------------------------------------------------------ #
# Test 2: READLINE_INPUT_FILTER_LIB with nonexistent file             #
# ------------------------------------------------------------------ #

# Nonexistent lib produces an error but bash still works.
result=$(READLINE_INPUT_FILTER_LIB=/nonexistent/lib.so "$THIS_SH" -c 'echo ok' 2>/dev/null)
assert_eq "nonexistent lib still runs" "ok" "$result"

# ------------------------------------------------------------------ #
# Test 3: Build and load test .so library                             #
# ------------------------------------------------------------------ #

TEST_LIB="$TEST_DIR/input-filter-lib-test.so"
gcc -shared -fPIC -o "$TEST_LIB" "$TEST_DIR/input-filter-lib-test.c" 2>/dev/null

if [ -f "$TEST_LIB" ]; then
    # Test that the library loads without crashing
    result=$(READLINE_INPUT_FILTER_LIB="$TEST_LIB" "$THIS_SH" -c 'echo loaded' 2>/dev/null)
    assert_eq "test lib loads" "loaded" "$result"

    # Test hot-reload: set the variable, then unset
    result=$(READLINE_INPUT_FILTER_LIB="$TEST_LIB" "$THIS_SH" -c '
        unset READLINE_INPUT_FILTER_LIB
        echo unloaded
    ' 2>/dev/null)
    assert_eq "test lib unload" "unloaded" "$result"

    rm -f "$TEST_LIB"
else
    echo "SKIP: could not compile test .so (gcc not available?)"
fi

# ------------------------------------------------------------------ #
# Test 4: READLINE_INPUT_FILTER_TIMEOUT variable parsing              #
# ------------------------------------------------------------------ #

# Default timeout (no variable set)
result=$("$THIS_SH" -c 'echo ${READLINE_INPUT_FILTER_TIMEOUT-unset}')
assert_eq "timeout default unset" "unset" "$result"

# Variable can be set
result=$(READLINE_INPUT_FILTER_TIMEOUT=50 "$THIS_SH" -c 'echo $READLINE_INPUT_FILTER_TIMEOUT')
assert_eq "timeout env passthrough" "50" "$result"

# ------------------------------------------------------------------ #
# Test 5: Pipe filter scripts are valid                               #
# ------------------------------------------------------------------ #

assert_ok "echo filter is valid bash" \
    bash -n "$TEST_DIR/input-filter-pipe-echo.sh"

assert_ok "upper filter is valid python" \
    python3 -c "compile(open('$TEST_DIR/input-filter-pipe-upper.py').read(), 'test', 'exec')"

# ------------------------------------------------------------------ #
# Test 6: Hex encode/decode round-trip via pipe filter                #
# ------------------------------------------------------------------ #

# Test the python filter's hex handling directly
result=$(echo '61\t0\t5\t0\t68656c6c6f' | python3 "$TEST_DIR/input-filter-pipe-upper.py")
assert_eq "python filter uppercase" "0	0	48454c4c4f" "$result"

# Empty line
result=$(echo '61\t0\t0\t0\t' | python3 "$TEST_DIR/input-filter-pipe-upper.py")
assert_eq "python filter empty" "0	0	" "$result"

# ------------------------------------------------------------------ #
# Test 7: Pipe filter with special characters                        #
# ------------------------------------------------------------------ #

# Hex for "hello world" = 68656c6c6f20776f726c64
result=$(echo '61\t5\t11\t0\t68656c6c6f20776f726c64' | python3 "$TEST_DIR/input-filter-pipe-upper.py")
assert_eq "python filter with space" "5	0	48454c4c4f20574f524c44" "$result"

# ------------------------------------------------------------------ #
# Test 8: Library filter and pipe filter are mutually exclusive       #
# ------------------------------------------------------------------ #

# When both are set, bash should not crash
result=$(
    READLINE_INPUT_FILTER="cat"
    READLINE_INPUT_FILTER_LIB=/nonexistent.so
    "$THIS_SH" -c 'echo both_set' 2>/dev/null
)
assert_eq "both filters set" "both_set" "$result"

# ------------------------------------------------------------------ #
# Test 9: special_vars hook — variable assignment triggers reload     #
# ------------------------------------------------------------------ #

# Assigning in a non-interactive shell should not crash
result=$("$THIS_SH" -c '
    READLINE_INPUT_FILTER_LIB=/nonexistent.so 2>/dev/null
    echo survived
' 2>/dev/null)
assert_eq "assign nonexistent lib" "survived" "$result"

# ------------------------------------------------------------------ #
# Test 10-22: SQLite history plugin                                   #
# ------------------------------------------------------------------ #

SQLITE_SRC="$TEST_DIR/../examples/loadables/readline_filter_history_sqlite.c"
SQLITE_LIB="$TEST_DIR/history_sqlite_test.so"
SQ="$TEST_DIR/sqlite3_query"
TMPHOME="$TEST_DIR/_testhome"

# Build the plugin and the sqlite3 query helper
gcc -shared -fPIC -O2 -o "$SQLITE_LIB" "$SQLITE_SRC" -lsqlite3 2>/dev/null
gcc -o "$SQ" "$TEST_DIR/sqlite3_query.c" -lsqlite3 2>/dev/null

if [ -f "$SQLITE_LIB" ] && [ -f "$SQ" ]; then

    rm -rf "$TMPHOME"
    mkdir -p "$TMPHOME"

    # Test 10: Plugin compiles
    PASS=$((PASS + 1))

    # Test 11: Interactive bash loads the plugin and creates DB.
    HOME="$TMPHOME" READLINE_INPUT_FILTER_LIB="$SQLITE_LIB" \
        "$THIS_SH" -i <<'CMDS' 2>/dev/null
exit
CMDS
    SQLITE_DB="$TMPHOME/.config/bash/history.sql"
    if [ -f "$SQLITE_DB" ]; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: sqlite db not created at $SQLITE_DB"
        SQLITE_DB="/dev/null"
    fi

    # Test 12: Schema has command column
    result=$("$SQ" "$SQLITE_DB" "SELECT sql FROM sqlite_master WHERE name='history'" 2>/dev/null)
    case "$result" in
        *command*TEXT*) PASS=$((PASS + 1)) ;;
        *) FAIL=$((FAIL + 1)); echo "FAIL: schema missing command TEXT: $result" ;;
    esac

    # Test 13: Direct SQL insert + query
    "$SQ" "$SQLITE_DB" "INSERT OR IGNORE INTO history (command, timestamp) VALUES ('git status', 1000)"
    "$SQ" "$SQLITE_DB" "INSERT OR IGNORE INTO history (command, timestamp) VALUES ('git commit -m test', 1001)"
    "$SQ" "$SQLITE_DB" "INSERT OR IGNORE INTO history (command, timestamp) VALUES ('docker ps', 1002)"
    result=$("$SQ" "$SQLITE_DB" "SELECT count(*) FROM history")
    if [ "$result" -ge 3 ] 2>/dev/null; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: should have >= 3 entries, got '$result'"
    fi

    # Test 14: Substring search
    result=$("$SQ" "$SQLITE_DB" \
        "SELECT command FROM history WHERE command LIKE '%git%' AND command != 'git' ORDER BY timestamp DESC LIMIT 1")
    case "$result" in
        *git*) PASS=$((PASS + 1)) ;;
        *) FAIL=$((FAIL + 1)); echo "FAIL: substring search got '$result'" ;;
    esac

    # Test 15: Deduplication
    "$SQ" "$SQLITE_DB" "INSERT INTO history (command) VALUES ('git status') ON CONFLICT(command) DO UPDATE SET timestamp = strftime('%s', 'now')"
    result=$("$SQ" "$SQLITE_DB" "SELECT count(*) FROM history WHERE command='git status'")
    assert_eq "dedup: single entry" "1" "$result"

    # Test 16: Most recent first
    "$SQ" "$SQLITE_DB" "INSERT INTO history (command) VALUES ('docker ps') ON CONFLICT(command) DO UPDATE SET timestamp = strftime('%s', 'now')"
    result=$("$SQ" "$SQLITE_DB" "SELECT command FROM history ORDER BY timestamp DESC LIMIT 1")
    assert_eq "most recent first" "docker ps" "$result"

    # Test 17: LIKE search with offset (pagination)
    r1=$("$SQ" "$SQLITE_DB" "SELECT command FROM history WHERE command LIKE '%git%' AND command != 'git' ORDER BY timestamp DESC LIMIT 1 OFFSET 0")
    r2=$("$SQ" "$SQLITE_DB" "SELECT command FROM history WHERE command LIKE '%git%' AND command != 'git' ORDER BY timestamp DESC LIMIT 1 OFFSET 1")
    if [ -n "$r1" ] && [ -n "$r2" ] && [ "$r1" != "$r2" ]; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: offset pagination: '$r1' vs '$r2'"
    fi

    # Test 18: Plugin creates dir if missing
    rm -rf "$TMPHOME/.config"
    HOME="$TMPHOME" READLINE_INPUT_FILTER_LIB="$SQLITE_LIB" \
        "$THIS_SH" -i <<'CMDS' 2>/dev/null
exit
CMDS
    if [ -f "$TMPHOME/.config/bash/history.sql" ]; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: db dir not recreated"
    fi

    # Test 19: Import from ~/.bash_history
    rm -rf "$TMPHOME/.config"
    printf 'echo hello\nls -la\ngit log --oneline\n' > "$TMPHOME/.bash_history"
    HOME="$TMPHOME" READLINE_INPUT_FILTER_LIB="$SQLITE_LIB" \
        "$THIS_SH" -i <<'CMDS' 2>/dev/null
exit
CMDS
    import_count=$("$SQ" "$TMPHOME/.config/bash/history.sql" "SELECT count(*) FROM history")
    if [ "$import_count" -ge 3 ] 2>/dev/null; then
        PASS=$((PASS + 1))
    else
        FAIL=$((FAIL + 1))
        echo "FAIL: import expected >= 3, got '$import_count'"
    fi

    # Test 20: Import with timestamps
    rm -rf "$TMPHOME/.config"
    printf '#1700000000\ncommand_with_ts\n#1700000001\nanother_with_ts\n' > "$TMPHOME/.bash_history"
    HOME="$TMPHOME" READLINE_INPUT_FILTER_LIB="$SQLITE_LIB" \
        "$THIS_SH" -i <<'CMDS' 2>/dev/null
exit
CMDS
    ts_result=$("$SQ" "$TMPHOME/.config/bash/history.sql" \
        "SELECT timestamp FROM history WHERE command='command_with_ts'")
    assert_eq "import preserves timestamps" "1700000000" "$ts_result"

    # Test 21: Empty LIKE matches all
    all=$("$SQ" "$TMPHOME/.config/bash/history.sql" "SELECT count(*) FROM history WHERE command LIKE '%%'")
    total=$("$SQ" "$TMPHOME/.config/bash/history.sql" "SELECT count(*) FROM history")
    assert_eq "empty LIKE matches all" "$total" "$all"

    # Test 22: Non-interactive bash -c does not crash
    result=$(HOME="$TMPHOME" READLINE_INPUT_FILTER_LIB="$SQLITE_LIB" \
        "$THIS_SH" -c 'echo noninteractive_ok' 2>/dev/null)
    assert_eq "non-interactive with sqlite" "noninteractive_ok" "$result"

    # Cleanup
    rm -f "$SQLITE_LIB" "$SQ"
    rm -rf "$TMPHOME"

else
    echo "SKIP: could not compile sqlite plugin or helper"
fi

# ------------------------------------------------------------------ #
# Summary                                                             #
# ------------------------------------------------------------------ #

echo ""
echo "input-filter tests: $PASS passed, $FAIL failed"

if [ $FAIL -gt 0 ]; then
    exit 1
fi
exit 0
